        <mxCell id="MGsdMgP7l0InPqgAwvWF-70" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="" vertex="1">
          <mxGeometry height="40" width="40" x="-840" y="720" as="geometry" />
        </mxCell>
        <mxCell id="MGsdMgP7l0InPqgAwvWF-71" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" value="" vertex="1">
          <mxGeometry height="40" width="40" x="-960" y="720" as="geometry" />
        </mxCell>
        <mxCell id="MGsdMgP7l0InPqgAwvWF-72" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;" value="" vertex="1">
          <mxGeometry height="40" width="40" x="-720" y="720" as="geometry" />
