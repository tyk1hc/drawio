        <mxCell id="Io5r8TIleDU7Dubmd4Zl-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Quorum Consensus - Definitions&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;R - Minimum number of nodes a reader needs to read from&lt;/li&gt;&lt;li&gt;W - Minimum number of nodes a writer needs to write to&amp;nbsp;&lt;/li&gt;&lt;li&gt;N - Number of nodes in the database cluster&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;b&gt;R + W &amp;gt; N -&amp;nbsp;&lt;/b&gt;Guarantees Strict Consistency&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="600" x="-1560" y="3610" as="geometry" />
        </mxCell>
        <mxCell id="Io5r8TIleDU7Dubmd4Zl-2" parent="1" style="text;whiteSpace=wrap;html=1;" value="In a 5-node cluster with read and write quorums of 3, any read operation is guaranteed to overlap with the latest write operation. This allows clients to compare record versions and identify the most recent value, ensuring consistency across the system." vertex="1">
          <mxGeometry height="40" width="680" x="-1560" y="3760" as="geometry" />
        </mxCell>
