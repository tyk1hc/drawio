        <mxCell id="MGsdMgP7l0InPqgAwvWF-60" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="znode_1" vertex="1">
