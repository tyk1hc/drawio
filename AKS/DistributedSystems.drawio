        <mxCell id="kIgsmheDJQz7XmRfPmZH-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;b&gt;Replication &lt;/b&gt;: Creating identical copies of all the data, and placing each copy on a different machine.&lt;/div&gt;&lt;div&gt;&lt;b&gt;Sharding&lt;/b&gt;: Splitting the data and placing each chunk on a different machine.&lt;/div&gt;" vertex="1">
