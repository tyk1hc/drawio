        <mxCell id="J-zNke_tOppB5j2uJXzS-51" parent="J-zNke_tOppB5j2uJXzS-49" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="?tenant=abc" vertex="1">
