          </mxGeometry>
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-51" parent="J-zNke_tOppB5j2uJXzS-49" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="?tenant=abc" vertex="1">
          <mxGeometry height="40" width="320" x="320" as="geometry">
            <mxRectangle height="40" width="320" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-52" parent="J-zNke_tOppB5j2uJXzS-30" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fixedHeader=1;" value="" vertex="1">
          <mxGeometry height="40" width="640" y="280" as="geometry" />
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-53" parent="J-zNke_tOppB5j2uJXzS-52" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="Subdomain" vertex="1">
          <mxGeometry height="40" width="320" as="geometry">
            <mxRectangle height="40" width="320" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-54" parent="J-zNke_tOppB5j2uJXzS-52" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="tenantA.example.com" vertex="1">
          <mxGeometry height="40" width="320" x="320" as="geometry">
            <mxRectangle height="40" width="320" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-55" parent="J-zNke_tOppB5j2uJXzS-30" style="shape=tableRow;horizontal=0;startSize=0;swimlaneHead=0;swimlaneBody=0;strokeColor=inherit;top=0;left=0;bottom=0;right=0;collapsible=0;dropTarget=0;fillColor=none;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;fixedHeader=1;" value="" vertex="1">
          <mxGeometry height="40" width="640" y="320" as="geometry" />
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-56" parent="J-zNke_tOppB5j2uJXzS-55" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="Custom Domain" vertex="1">
          <mxGeometry height="40" width="320" as="geometry">
            <mxRectangle height="40" width="320" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-57" parent="J-zNke_tOppB5j2uJXzS-55" style="shape=partialRectangle;html=1;whiteSpace=wrap;connectable=0;strokeColor=inherit;overflow=hidden;fillColor=none;top=0;left=0;bottom=0;right=0;pointerEvents=1;" value="company.com" vertex="1">
          <mxGeometry height="40" width="320" x="320" as="geometry">
            <mxRectangle height="40" width="320" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-58" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=14;" value="&lt;div&gt;&lt;font&gt;The pipeline executes them in order.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;The &lt;b&gt;first valid strategy&lt;/b&gt; can resolve the tenant, but if multiple strategies resolve &lt;b&gt;different tenants&lt;/b&gt;, the request is rejected to prevent spoofing.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;Example:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;Header: Tenant A&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;JWT: Tenant B&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;-&amp;gt; Reject Request.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;b&gt;TenantContext&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;This is the core concept.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;It stores the current tenant for the lifetime of a single HTTP request.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;font&gt;Request Starts&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;TenantContext (TenantId = A)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Services&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Respositories&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;DbContext&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font&gt;Request Ends&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;It has a &lt;b&gt;Scoped &lt;/b&gt;lifetime (one instance per request)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;b&gt;Read vs Write&lt;/b&gt;&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;Application reads: &lt;b&gt;ITenantContext&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;Infrastructure writes: &lt;b&gt;IMutableTenantContext&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;This prevents application services from modifying the current tenant.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;b&gt;TenantResolutionRequest&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;Instead of exposing HttpContext to the Application layer, Infrastructure creates a simplified request model containing only the data needed for tenant resolution:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Host&lt;/li&gt;&lt;li&gt;Headers&amp;nbsp;&lt;/li&gt;&lt;li&gt;Route values&lt;/li&gt;&lt;li&gt;Query values&lt;/li&gt;&lt;li&gt;Cookies&lt;/li&gt;&lt;li&gt;TenantIdentityContext&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;This keeps Application independent of ASP.NET Core.&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="720" width="640" x="360" y="760" as="geometry" />
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-60" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;TenantIdentityContext&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;This abstracts the authenticated user&#39;s identity.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Instead of exposing JWT or ClaimsPrincipal, it contains:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;IsAuthenticated&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;UserId&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Email&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Claims&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Infrastructure maps authentication details into this model, allowing Application to remain authentication-agnostic.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;TenantResolutionResult&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Rather than returning only a Guid, the resolver returns a richer result:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;IsResolved&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;TenantId&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;TenantCode&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;TenantName&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Source&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Description&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;This makes debugging and auditing easier because the system knows how the tenant was resolved.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Example&lt;/b&gt;:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant: Acme&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Source: JWT&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Description: Resolved from JWT claim&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;API Key Design&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The API key flow is:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Request&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;X-API-Key&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;ApiKeyTenantStrategy&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;IApiKeyValidator&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Repository&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Database&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Security rules:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Never store raw API keys.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Store only:&lt;/font&gt;&lt;/li&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;KeyHash&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Prefix&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;This follows standard practices similar to password storage.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Database Tenant Isolation&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;All tenant-owned entities inherit from: &lt;b&gt;TenantAwareEntity&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Which implements: &lt;b&gt;ITenantOwnedEntity&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Every entity therefore has: &lt;b&gt;TenantId&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;An EF Core Global Query Filter automatically scopes queries to the current tenant.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Example:&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Instead of: SELECT * FROM Orders&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;EF Core transparently executes: SELECT * FROM Orders Where TenantId = CurrentTenant&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Save Protection&amp;nbsp;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Two mechanisms enfore tenant integrity when writing data:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;TenantEntityInterceptor&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;On insert, it automatically assigns the current TenantId to new entities.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Example: db.Add(order)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;becomes: order.TenantId = CurrentTenantId;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;TenantSaveChangesValidator&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Before saving, it verifies that an entity&#39;s TenantId matches the current tenant.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;If someones attempts to change an entity&#39;s tenant: order.TenantId = AnotherTenant;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;the save is blocked.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;This prevents tenant switching attacks.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1240" width="640" x="1080" y="80" as="geometry" />
        </mxCell>
        <mxCell id="J-zNke_tOppB5j2uJXzS-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Middleware Order&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The request pipeline is carefully ordered:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Exception Handler&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;HTTPS&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Authentication&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant Resolution&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant Validation&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Authorization&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Controllers&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The order matters because:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ol&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Authentication provides user identity (e.g., JWT claims).&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant Resolution may use that identity to determine the tenant.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant Validation confirms the tenant is valid and active.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Authorization then checks permissions within the correct tenant context.&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;h1 data-section-id=&quot;o1iqxw&quot; data-start=&quot;7176&quot; data-end=&quot;7232&quot; class=&quot;PDq2pG_selectionAnchorContainer&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Future Enhancements (Not for Immediate Implementation)&lt;span aria-hidden=&quot;true&quot; class=&quot;PDq2pG_selectionAnchor&quot;&gt;&lt;/span&gt;&lt;/font&gt;&lt;/h1&gt;&lt;p data-start=&quot;7234&quot; data-end=&quot;7299&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;These are intentionally deferred until the core system is stable:&lt;/font&gt;&lt;/p&gt;&lt;ul data-start=&quot;7301&quot; data-end=&quot;7619&quot;&gt;&lt;li data-section-id=&quot;b3d0h2&quot; data-start=&quot;7301&quot; data-end=&quot;7335&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Redis caching for tenant lookups&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;x12wyf&quot; data-start=&quot;7336&quot; data-end=&quot;7365&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant onboarding workflows&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1yfbgqa&quot; data-start=&quot;7366&quot; data-end=&quot;7424&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Tenant lifecycle management (Active, Suspended, Deleted)&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;vbb6ar&quot; data-start=&quot;7425&quot; data-end=&quot;7440&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Feature flags&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1i61bix&quot; data-start=&quot;7441&quot; data-end=&quot;7467&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Quotas and rate limiting&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1dtgmuw&quot; data-start=&quot;7468&quot; data-end=&quot;7492&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Improved audit logging&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;utukzg&quot; data-start=&quot;7493&quot; data-end=&quot;7536&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Background job tenant context propagation&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1sox66r&quot; data-start=&quot;7537&quot; data-end=&quot;7562&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Cross-tenant admin mode&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;1n6ah3d&quot; data-start=&quot;7563&quot; data-end=&quot;7590&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Data migration strategies&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li data-section-id=&quot;wg04r4&quot; data-start=&quot;7591&quot; data-end=&quot;7619&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Better integration testing&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p data-start=&quot;7621&quot; data-end=&quot;7714&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The instruction is to &lt;strong data-start=&quot;7643&quot; data-end=&quot;7673&quot;&gt;review before implementing&lt;/strong&gt; and avoid adding complexity prematurely.&lt;/font&gt;&lt;/p&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Key Design Principles&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;The architecture consistently follows these principles:&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Separation of concerns&lt;/b&gt;: Each layer has a single responsibility.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Framework independence&lt;/b&gt;: Application and Domain are isolated from ASP.NET Core and authentication details.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Security by default&lt;/b&gt;: Tenant isolation is enforced at the request level (resolution/validation) and data level (query filter and save validation)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Extensibility&lt;/b&gt;: New tenant resolution mechanisms can be added by implementing &lt;i&gt;ITenantResolutionStrategy &lt;/i&gt;without changing the pipeline.&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Maintanability&lt;/b&gt;: Middleware orchestrates, Infrastructure handles technical details, and business logic remains in the Application layer.&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Overall, this is a well-structured, production-oriented multi-tenant architecture that prioritizes correctness, security, and&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;clean boundaries over unnecessary complexity.&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="800" width="750" x="1800" y="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
